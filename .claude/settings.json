{
  "statusLine": {
    "type": "command",
    "command": "python \"${CLAUDE_PROJECT_DIR:-.}/.claude/statusline.py\""
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Agent|Skill|Task",
        "hooks": [
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/.claude/hooks/usage_log.py\"",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/.claude/hooks/format_dart.py\"",
            "timeout": 90
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/.claude/hooks/verify_nudge.py\"",
            "timeout": 30
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(flutter analyze *)",
      "Bash(flutter analyze)",
      "Bash(flutter test *)",
      "Bash(flutter test)",
      "Bash(flutter pub get)",
      "Bash(dart format *)",
      "Bash(dart analyze *)",
      "Bash(dart run tool/*)",
      "Bash(cd flutter_app && flutter test *)",
      "Bash(cd flutter_app && flutter analyze *)",
      "Bash(cd flutter_app && flutter analyze)",
      "Bash(cd flutter_app && flutter pub get)",
      "Bash(cd flutter_app && dart format *)",
      "Bash(cd flutter_app && dart run tool/*)",
      "Bash(cd flutter_app && flutter pub get *)",
      "Bash(git status *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git diff)",
      "Bash(git log *)",
      "Bash(git branch *)",
      "Bash(git show *)",
      "Bash(git rev-parse *)",
      "Bash(git stash list *)",
      "Bash(git stash list)",
      "Bash(git worktree list *)",
      "Bash(git worktree list)",
      "Bash(git worktree add *)",
      "Skill(vittrade *)",
      "Skill(code-review-and-quality)",
      "Agent(flutter *)"
    ],
    "ask": [
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git reset --hard*)",
      "Bash(git push *)",
      "Bash(git commit *)"
    ],
    "deny": [
      "Bash(git clean *)",
      "Bash(git clean)",
      "Bash(rm -rf .claude*)",
      "Bash(rm -rf flutter_app*)",
      "Bash(rm -rf .git*)",
      "Bash(rm -rf /)",
      "Bash(rm -rf ~)"
    ]
  }
}
