{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "flutter-web",
      "runtimeExecutable": "flutter",
      "runtimeArgs": ["run", "-d", "web-server", "--web-port", "8765"],
      "port": 8765,
      "cwd": "flutter_app"
    },
    {
      "name": "vittrade-static",
      "runtimeExecutable": "node",
      "runtimeArgs": ["serve_static.js"],
      "port": 8766,
      "cwd": "flutter_app/build"
    }
  ]
}
