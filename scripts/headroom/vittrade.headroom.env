# VitTrade Headroom proxy preset — quality-first token savings.
# Copy overrides to vittrade.headroom.local.env (gitignored) for personal tweaks.

HEADROOM_MODE=token
HEADROOM_CODE_AWARE_ENABLED=true
HEADROOM_BETA_HEADER_STICKY=enabled
HEADROOM_MEMORY_INJECTION_MODE=live_zone_tail
HEADROOM_UPDATE_CHECK=on

# Phase 2 (enable after 1 stable week — uncomment in local override):
# HEADROOM_OUTPUT_SHAPER=1
# HEADROOM_OUTPUT_HOLDOUT=0.1

# Corporate SSL only if headroom doctor reports cert errors:
# HEADROOM_TLS_STRICT=0
